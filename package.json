{
  "name": "@exotel-npm-dev/exotel-ai-assist",
  "version": "1.1.3",
  "description": "AI-powered real-time suggestions, transcript, and sentiment for agent calls",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "require": "./dist/react/index.js",
      "default": "./dist/react/index.js"
    },
    "./controller": {
      "types": "./dist/controller/index.d.ts",
      "require": "./dist/controller/index.js",
      "default": "./dist/controller/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "react": [
        "dist/react/index.d.ts"
      ],
      "controller": [
        "dist/controller/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "react.js",
    "controller.js"
  ],
  "scripts": {
    "build": "tsc --emitDeclarationOnly && NODE_ENV=production rollup --config rollup.config.mjs",
    "dev": "rollup --config rollup.config.mjs --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^20.0.0",
    "@types/object-hash": "^3.0.6",
    "@types/react": "^16.14.0",
    "@types/react-dom": "^16.9.0",
    "postcss": "^8.5.8",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "rollup": "^4.59.0",
    "rollup-plugin-postcss": "^4.0.2",
    "tslib": "^2.8.1",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "eventemitter3": "^5.0.1",
    "lucide-react": "^0.263.0",
    "object-hash": "^3.0.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=16"
  },
  "keywords": [
    "exotel",
    "ai",
    "assist",
    "call",
    "websocket",
    "transcript",
    "sentiment",
    "suggestion"
  ]
}
