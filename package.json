{
  "name": "@exotel-npm-dev/exotel-ai-assist",
  "version": "1.0.0",
  "description": "AI-powered real-time suggestions, transcript, and sentiment for agent calls",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "default": "./dist/react/index.js"
    },
    "./controller": {
      "types": "./dist/controller/index.d.ts",
      "import": "./dist/controller/index.js",
      "default": "./dist/controller/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "react": [
        "dist/react/index.d.ts"
      ],
      "controller": [
        "dist/controller/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --emitDeclarationOnly && webpack --config webpack.config.js",
    "dev": "webpack --config webpack.config.js --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/object-hash": "^3.0.6",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "css-loader": "^7.1.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.4.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@radix-ui/themes": "^3.2.1",
    "eventemitter3": "^5.0.1",
    "lucide-react": "^0.469.0",
    "object-hash": "^3.0.0",
    "react-hot-toast": "^2.6.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=16"
  },
  "keywords": [
    "exotel",
    "ai",
    "assist",
    "call",
    "websocket",
    "transcript",
    "sentiment",
    "suggestion"
  ]
}
